<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KR - {{ title }}</title>
  <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='16' fill='%23DEEE81'/%3E%3C/svg%3E">
  <script src="{{ '/assets/js/main.js' | url }}" defer></script>
</head>
<body class="{% if title == 'Kallie Rollenhagen' %}home-layout{% endif %}">
  <div id="grid-container">
  {% include "partials/header.njk" %}
    <main class="grid-inherit">
      {{ content | safe }}
    </main>
  </div>
  {% if scripts %}
    {% for scriptPath in scripts %}
      <script src="{{ scriptPath | url }}"></script>
    {% endfor %}
  {% endif %}
</body>
</html>