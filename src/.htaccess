# ----------------------------------------------------------------------
# 1. INITIALIZATION & SAFETY CONTROLS
# ----------------------------------------------------------------------
RewriteEngine On
RewriteBase /

# Stop Apache from forcing trailing slashes on physical directories
DirectorySlash Off

# ----------------------------------------------------------------------
# 2. THE ADMIN CMS FIX
# ----------------------------------------------------------------------
# If someone requests exactly "admin" without a slash, 
# force a clean external browser redirect to "/admin/"
RewriteCond %{REQUEST_URI} ^/admin$ [NC]
RewriteRule ^(.*)$ /admin/ [R=301,L]

# ----------------------------------------------------------------------
# 3. THE DESIGN CONFLICT FIX
# ----------------------------------------------------------------------
# If they request exactly "design/" with a slash, 
# force an external redirect to clean "/design"
RewriteCond %{THE_REQUEST} \s/design/ [NC]
RewriteRule ^design/$ /design [R=301,L]

# If they request exactly "design" (no slash), 
# invisibly serve the flat design.html file generated by Eleventy
RewriteRule ^design$ design.html [NC,L]

# ----------------------------------------------------------------------
# 4. STANDARD EXTENSIONLESS URLs
# ----------------------------------------------------------------------
# For Art, About, Photography, and Design Subpages.
# If the request isn't a directory, but a matching .html file exists, serve it!
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]