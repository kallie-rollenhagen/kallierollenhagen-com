# 1. Turn on the Apache Rewrite Engine
RewriteEngine On

# 2. CRITICAL: Stop Apache from automatically forcing trailing slashes on folders
# DirectorySlash Off


# 3. ADMIN CMS
# If someone visits /admin, redirect them to /admin/
RewriteRule ^admin$ /admin/ [R=301,L]


# 4. DESIGN CONFLICT FIX
# If someone explicitly types "design/" with a slash, redirect to clean "/design"
RewriteCond %{THE_REQUEST} \s/design/ [NC]
RewriteRule ^design/$ /design [R=301,L]

# If they request exactly "design" (no slash), invisibly serve design.html
RewriteRule ^design$ design.html [NC,L]


# 5. STANDARD EXTENSIONLESS URLS
# For Art, About, Photography, and Design Subpages
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]


### ORIGINAL HTACCESS

# Turn on the Apache Rewrite Engine
# RewriteEngine On

# Tell the server this site lives inside your specific temporary subdirectory
# RewriteBase /website_e1e2df13/

# RULE 1: THE DESIGN CONFLICT FIX
# If someone requests exactly "design" or "design/", skip checking the directory
# and serve design.html immediately.
# RewriteRule ^design/?$ design.html [NC,L]

# RULE 2: STANDARD EXTENSIONLESS URLS (For Art, About, Photography, and Design Subpages)
# If the request is not an actual directory that exists, look for a matching .html file
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteCond %{REQUEST_FILENAME}.html -f
# RewriteRule ^([^\.]+)$ $1.html [NC,L]