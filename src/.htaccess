# 1. Turn on the Apache Rewrite Engine
RewriteEngine On

# 2. CRITICAL: Stop Apache from automatically forcing trailing slashes on folders
DirectorySlash Off


# 3. THE ADMIN CMS FIX (Force Actual Browser Redirect to /admin/)
# If they request exactly "admin" without a slash...
RewriteCond %{REQUEST_URI} ^/admin$ [NC]
# ...force the browser to execute a visible 301 redirect to "/admin/"
RewriteRule ^(.*)$ /admin/ [R=301,L]


# 4. THE DESIGN CONFLICT FIX
# If someone explicitly types "design/" with a slash, redirect them to clean "/design"
RewriteCond %{THE_REQUEST} \s/design/ [NC]
RewriteRule ^design/$ /design [R=301,L]

# If they request exactly "design" (no slash), invisibly serve design.html
RewriteRule ^design$ design.html [NC,L]


# 5. STANDARD EXTENSIONLESS URLs
# For Art, About, Photography, and Design Subpages
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]


### ORIGINAL HTACCESS

