# 1. Turn on the Apache Rewrite Engine
RewriteEngine On

# 2. CRITICAL: Stop Apache from automatically forcing trailing slashes on folders
DirectorySlash Off

RewriteRule ^admin$ /admin/ [R=301,L]

# 3. RULE 1: THE ADMIN CMS FIX
# If someone explicitly types "admin/" with a slash, redirect them to clean "/admin"
RewriteCond %{THE_REQUEST} \s/admin/ [NC]
RewriteRule ^admin/$ /admin [R=301,L]

# If they request exactly "admin" (no slash), invisibly serve the internal index file!
RewriteRule ^admin$ admin/index.html [NC,L]


# 4. RULE 2: THE DESIGN CONFLICT FIX
# If someone explicitly types "design/" with a slash, redirect them to clean "/design"
RewriteCond %{THE_REQUEST} \s/design/ [NC]
RewriteRule ^design/$ /design [R=301,L]

# If they request exactly "design" (no slash), invisibly serve design.html
RewriteRule ^design$ design.html [NC,L]


# 5. RULE 3: STANDARD EXTENSIONLESS URLs
# For Art, About, Photography, and Design Subpages
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]


