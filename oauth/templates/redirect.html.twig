<html>

<body>
<h1>TEMPLATE TEST</h1>

    <script>
  (function () {
    var content = {{ content | raw }};
    var token = content.token;
    var sent = false;

    function receiveMessage(e) {
      console.log("REPLY RECEIVED:", JSON.stringify(e.data), "from:", e.origin);
      
      // Ignore Angular DevTools messages (they are objects, not strings)
      if (typeof e.data !== 'string') {
        console.log("IGNORING - not a string");
        return;
      }

      if (sent) return;
      sent = true;

      console.log("Sending token in response to:", e.data);
      window.opener.postMessage(
        'authorization:github:success:' + JSON.stringify({token: token, provider: "github"}),
        e.origin
      );
      window.removeEventListener("message", receiveMessage);
      setTimeout(function() { window.close(); }, 500);
    }

    window.addEventListener("message", receiveMessage, false);
    window.opener.postMessage("authorizing:github", "*");
    console.log("Sent authorizing:github, waiting for string reply...");
  })()
</script>

    {% if error %}
    <h1>ERROR: {{ error }}</h1>
    <p>{{ error_description }}</p>
    {% endif %}
</body>

</html>